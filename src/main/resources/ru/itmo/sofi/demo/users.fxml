<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400" prefWidth="850" spacing="10" style="-fx-padding: 10;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="ru.itmo.sofi.demo.UserController">

    <children>
        <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Пользователи" />
        <TableView fx:id="userTable" prefHeight="320">
            <columns>
                <TableColumn fx:id="loginColumn" prefWidth="180" text="Логин" />
                <TableColumn fx:id="passwordColumn" prefWidth="500" text="Хэш пароля" />
                <TableColumn fx:id="adminColumn" prefWidth="100" text="Админ" />
            </columns>
        </TableView>
        <HBox spacing="10">
            <children>
                <Button onAction="#onResetPassword" text="Сбросить пароль" />
            <Button mnemonicParsing="false" onAction="#onStatusAdmin" text="Админы" />
                <Button onAction="#onClose" text="Закрыть" />
            </children>
        </HBox>
    </children>
</VBox>
